# 环境变量配置示例
# 复制为 .env 并修改

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
READ_TIMEOUT=10s
WRITE_TIMEOUT=10s

# 游戏配置
GAME_TICK_RATE=60
GAME_MAX_PLAYERS=1000
GAME_MAX_ROOMS=100
GAME_ROOM_SIZE=10
GAME_MAP_SIZE=100.0
GAME_SPAWN_DISTANCE=10.0

# Redis 配置
REDIS_ENABLED=true
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# 监控配置
METRICS_ENABLED=true
METRICS_PORT=9090

# Grafana 配置 (监控模式)
GF_SECURITY_ADMIN_PASSWORD=admin

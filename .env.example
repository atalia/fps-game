# 环境变量配置

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# 游戏配置
GAME_TICK_RATE=60
GAME_MAX_PLAYERS=1000
GAME_MAX_ROOMS=100

# Redis 配置
REDIS_ENABLED=true
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# 监控配置
METRICS_ENABLED=true
METRICS_PORT=9090

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# 前端配置
CLIENT_PATH=/app/client

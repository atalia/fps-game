{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "match_ended.json",
  "title": "MatchEnded",
  "description": "Broadcast when the match is over",
  "type": "object",
  "required": ["winner", "round_number"],
  "properties": {
    "winner": { "type": "string", "enum": ["ct", "t"] },
    "round_number": { "type": "integer", "minimum": 1 },
    "is_overtime": { "type": "boolean" }
  },
  "additionalProperties": true
}

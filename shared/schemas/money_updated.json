{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "money_updated.json",
  "title": "MoneyUpdated",
  "description": "Sent to a player when their money changes",
  "type": "object",
  "required": ["player_id", "money"],
  "properties": {
    "player_id": {
      "type": "string",
      "description": "Player identifier"
    },
    "money": {
      "type": "integer",
      "minimum": 0,
      "description": "Current money total"
    },
    "delta": {
      "type": "integer",
      "description": "Change applied to the total"
    },
    "reason": {
      "type": "string",
      "enum": ["purchase", "kill", "round_win", "round_loss"],
      "description": "Reason the money changed"
    }
  },
  "additionalProperties": true
}

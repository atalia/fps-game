{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "voice_data.json",
  "title": "VoiceData",
  "description": "Broadcast voice audio data",
  "type": "object",
  "required": ["playerId", "audio"],
  "properties": {
    "playerId": {
      "type": "string",
      "description": "Speaking player's identifier"
    },
    "audio": {
      "type": "string",
      "description": "Base64 encoded audio data"
    }
  },
  "additionalProperties": false
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "room_joined.json",
  "title": "RoomJoined",
  "description": "Sent to client when successfully joining a room",
  "type": "object",
  "required": ["room_id", "player_id", "players"],
  "properties": {
    "room_id": {
      "type": "string",
      "description": "Room identifier"
    },
    "player_id": {
      "type": "string",
      "description": "Current player's identifier"
    },
    "players": {
      "type": "array",
      "description": "List of players already in room",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "health": { "type": "integer", "minimum": 0, "maximum": 100 },
          "position": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            }
          },
          "is_bot": { "type": "boolean" },
          "kills": { "type": "integer" },
          "deaths": { "type": "integer" }
        }
      }
    }
  },
  "additionalProperties": true
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["player_id", "position", "health"],
  "properties": {
    "player_id": {
      "type": "string"
    },
    "position": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },
    "health": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "armor": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "has_helmet": {
      "type": "boolean"
    },
    "ammo": {
      "type": "integer",
      "minimum": 0
    }
  }
}

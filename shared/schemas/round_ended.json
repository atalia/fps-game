{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "round_ended.json",
  "title": "RoundEnded",
  "description": "Broadcast when a round ends",
  "type": "object",
  "required": ["round_number", "winner", "reason", "announcement"],
  "properties": {
    "round_number": { "type": "integer", "minimum": 1 },
    "winner": { "type": "string", "enum": ["ct", "t"] },
    "reason": { "type": "string", "enum": ["elimination", "time", "explosion", "defused"] },
    "announcement": { "type": "string" },
    "is_halftime": { "type": "boolean" },
    "is_overtime": { "type": "boolean" },
    "mvp": {
      "type": "object",
      "required": ["player_id", "name", "kills", "damage"],
      "properties": {
        "player_id": { "type": "string" },
        "name": { "type": "string" },
        "kills": { "type": "integer", "minimum": 0 },
        "damage": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "additionalProperties": true
}

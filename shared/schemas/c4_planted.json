{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "c4_planted.json",
  "title": "C4Planted",
  "description": "Broadcast when the C4 has been planted",
  "type": "object",
  "required": ["player_id", "position"],
  "properties": {
    "player_id": { "type": "string" },
    "position": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },
    "team": { "type": "string", "enum": ["ct", "t"] },
    "explosion_in": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": true
}
